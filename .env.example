# ---- Base de datos PostgreSQL ----
# Local (desarrollo)
DATABASE_URL=postgresql://petrobox:petrobox@localhost:5432/floreria

# Producción (bilbo por Tailscale, puerto 2002)
# DATABASE_URL=postgresql://petrobox:petrobox@bilbo:2002/floreria

# Pon PGSSL=true si el servidor exige TLS
# PGSSL=false

# Secreto para firmar las sesiones (cookies). Cambiar en producción.
AUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
