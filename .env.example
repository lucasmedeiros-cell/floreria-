# ---- Base de datos PostgreSQL ----
# Local (desarrollo)
DATABASE_URL=postgresql://petrobox:petrobox@localhost:5432/floreria

# Producción (bilbo por Tailscale, puerto 2002)
# DATABASE_URL=postgresql://petrobox:petrobox@bilbo:2002/floreria

# Pon PGSSL=true si el servidor exige TLS
# PGSSL=false

# Secreto para firmar las sesiones (cookies). Cambiar en producción.
AUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ---- Integración con COMANDER (dashboard central) ----
# Token compartido para la API de lectura /api/central/*. Generar uno propio.
CENTRAL_API_TOKEN=cmdr_genera-un-token-aleatorio

# ---- Reporte de bugs → Tickets (botón "Debug") ----
# API key del app_client de FloresOnline en tickets.petroboxinc.com (canal
# público /api/public/report). Server-side; los tickets entran en "desarrollo".
TICKETS_API=https://tickets.petroboxinc.com/api
# TICKETS_API_KEY=pbx_...

# ---- Vendedor 24/7 (bot de WhatsApp con IA) ----
# Probar todo local (sin WhatsApp real):
#   POST /api/whatsapp/simulate  { "text": "Hola, quiero un ramo" }

# --- IA (Claude) ---
# Modo 1: token de la CUENTA (suscripción/OAuth). Es lo que se usa hoy: si hay
#   sesión de Claude Code, el bot lee el token de ~/.claude/.credentials.json
#   automáticamente. Para forzarlo/desplegarlo, exportar el access token:
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...
# Modo 2: API key clásica (tiene prioridad si está presente):
# ANTHROPIC_API_KEY=sk-ant-...
# Sin ninguno → respuestas simuladas.

# --- WhatsApp ---
# Transporte ACTUAL: Baileys (número por QR). No necesita variables: se vincula
#   desde Admin → Configuración → Vendedor 24/7 → Conectar WhatsApp.
#   La sesión se guarda en ./.wa-auth (ignorado por git).
# Alternativa: WhatsApp Cloud API oficial (Meta), si algún día se migra:
# META_WA_TOKEN=EAAG...
# META_WA_PHONE_ID=1234567890
# META_WA_VERIFY_TOKEN=floresonline_8a6dd6d27a2607b9
# WA_GRAPH_VERSION=v21.0
